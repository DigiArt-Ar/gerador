<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerador QR Code - DigiArt AR</title>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <style>
        :root {
            --azul-escuro: #1A3C5E; /* Cores DigiArt */
            --azul-claro: #4F93BF;
            --dourado: #FFD700;
            --fundo: #E6F0F5;
        }

        body { 
            font-family: 'Segoe UI', Roboto, sans-serif; 
            background-color: var(--fundo); 
            margin: 0; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh;
            padding: 20px;
        }

        .card-qr {
            background: #fff; 
            width: 100%;
            max-width: 450px;
            padding: 30px; 
            border-radius: 20px; 
            box-shadow: 0 15px 35px rgba(26, 60, 94, 0.15); 
            border-top: 8px solid var(--azul-escuro);
            text-align: center;
        }

        h1 { font-size: 2rem; color: var(--azul-escuro); margin-bottom: 5px; font-weight: 800; }
        h1 span { color: var(--azul-claro); }
        .subtitulo { font-size: 14px; color: #666; margin-bottom: 25px; }

        input { 
            width: 100%; 
            padding: 15px; 
            border: 2px solid #D1E1EB; 
            border-radius: 10px; 
            box-sizing: border-box; 
            font-size: 16px; 
            margin-bottom: 20px;
            transition: 0.3s;
        }
        input:focus { border-color: var(--azul-claro); outline: none; }

        .btn { 
            width: 100%; 
            padding: 16px; 
            border: none; 
            border-radius: 10px; 
            font-size: 1.1rem; 
            font-weight: 800; 
            cursor: pointer; 
            text-transform: uppercase;
            transition: 0.3s;
        }
        
        /* Botão Dourado de Gerar */
        .btn-gerar { background-color: var(--dourado); color: var(--azul-escuro); }
        .btn-gerar:hover { background-color: #B8860B; color: #fff; transform: translateY(-2px); }

        /* Resultado (Canvas e Botão Verde) */
        #resultado-qr {
            margin-top: 25px;
            padding: 20px;
            background: #fafafa;
            border-radius: 15px;
            border: 2px dashed #ccc;
            display: none; /* Escondido até gerar */
        }
        
        #qrcode-view { display: flex; justify-content: center; margin-bottom: 15px; }
        canvas { border: 5px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        
        .btn-down { background-color: #27ae60; color: white; margin-top: 10px; font-size: 0.9rem; }
    </style>
</head>
<body>

    <div class="card-qr">
        <h1>DigiArt <span>AR</span></h1>
        <p class="subtitulo">Gerador de QR Code Interativo</p>
        
        <input type="text" id="urlInput" placeholder="Cole o link do GitHub Pages aqui...">
        
        <button class="btn btn-gerar" onclick="gerarQR()">Gerar QR Code ✨</button>
        
        <div id="resultado-qr">
            <div id="qrcode-view"></div>
            
            <p style="font-size: 12px; color: #666; margin-bottom: 10px;">Clique no botão para baixar a imagem (PNG)</p>
            <button class="btn btn-down" onclick="downloadPNG()">📥 BAIXAR QR CODE (PNG)</button>
        </div>
    </div>

    <script>
        function gerarQR() {
            const link = document.getElementById("urlInput").value;
            const view = document.getElementById("qrcode-view");
            const box = document.getElementById("resultado-qr");
            
            if(!link) { 
                alert("Por favor, cole um link!"); 
                return; 
            }

            // Limpa o QR anterior
            view.innerHTML = "";
            box.style.display = "block";

            // Gera o QR Code em PRETO (#000000)
            new QRCode(view, {
                text: link,
                width: 250, // Resolução boa para imprimir
                height: 250,
                colorDark : "#000000",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.H
            });
        }

        function downloadPNG() {
            const canvas = document.querySelector("#qrcode-view canvas");
            if(!canvas) return;
            
            const link = document.createElement('a');
            link.download = 'qrcode-digiart.png';
            link.href = canvas.toDataURL("image/png");
            link.click();
        }
    </script>
</body>
</html>
